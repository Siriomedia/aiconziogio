# MongoDB - usa Railway MongoDB plugin oppure MongoDB Atlas
MONGO_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=aiconziogio

# Resend - per le email del form contatti (opzionale, usa MOCK_KEY per disabilitare)
RESEND_API_KEY=MOCK_KEY
SENDER_EMAIL=onboarding@resend.dev
CONTACT_RECIPIENT_EMAIL=aiconziogio@gmail.com

# Instagram (opzionale - per il feed Instagram)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USERNAME=aiconziogio

# CORS - inserisci l'URL del frontend su Railway (es. https://aiconziogio-frontend.up.railway.app)
CORS_ORIGINS=https://your-frontend.up.railway.app
